# ============================================================
# sgagent — OpenAI 兼容端点配置(示例)
# 用法:cp .env.sample .env,然后填入 API_KEY 即可
# 换 BASE_URL + API_KEY + MODEL_ID 可接入任意 OpenAI 兼容后端
# ============================================================

# === 端点 ===
# 任意 OpenAI 兼容协议的 /v1 根地址。示例:
#   小米 MiMo   https://api.xiaomimimo.com/v1   (默认)
#   DeepSeek    https://api.deepseek.com/v1
#   自建 vLLM   http://localhost:8000/v1
#   Ollama      http://localhost:11434/v1
BASE_URL=https://api.xiaomimimo.com/v1

# === API Key(必填)===
# 对应端点的 bearer key
API_KEY=your-key-here

# === 模型 ===
# 发给 API 的模型名,取决于端点支持哪些(mimo-v2.5 / deepseek-chat / gpt-4o / llama3...)
MODEL_ID=mimo-v2.5

# === 模型能力(可选,以下为默认值)===
# REASONING:模型是否支持推理/思考(deepseek thinkingFormat + reasoning_content 字段)。
#   推理模型(MiMo/DeepSeek-R1/Qwen-thinking...)保持 true;
#   非推理模型(GPT-4o/Claude-via-proxy/普通对话模型)设 false,否则请求可能被拒。
REASONING=true
# CONTEXT_WINDOW:模型上下文窗口(token),仅供输出长度截断估算用
CONTEXT_WINDOW=1048576
# MAX_TOKENS:默认最大输出 token 数
MAX_TOKENS=131072

# === 运行时(可选,默认值见下,通常不用改)===
# FAGENT_HOME:所有状态(会话 + trace)的根目录。不设 = ~/.fagent。
#   注意:Node 不展开 ~,自定义时请写绝对路径(如 /home/you/.fagent)。
#   也可放进全局 ~/.fagent/.env 跨项目共享;项目级 ./.env 覆盖全局。
# FAGENT_HOME=/home/you/.fagent
# VIEW_PORT:trace viewer 端口(npm run view)。默认 4789。
# VIEW_PORT=4789
